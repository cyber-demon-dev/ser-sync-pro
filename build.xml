<?xml version="1.0" encoding="UTF-8"?>
<project name="cdd-sync-pro" default="all" basedir=".">
    
    <description>
        cdd-sync-pro - Serato crate synchronization tool
        session-fixer - Standalone session path fixer
        Build script for compiling and packaging both applications
    </description>
    
    <!-- Properties -->
    <property name="shared.dir" value="shared/src"/>
    <property name="src.dir" value="cdd-sync-pro/src"/>
    <property name="build.dir" value="out/production/cdd-sync-pro"/>
    <property name="dist.dir" value="distr/cdd-sync-pro"/>
    <property name="session.dist.dir" value="distr/session-fixer"/>
    <property name="jar.name" value="cdd-sync-pro.jar"/>
    <property name="session.jar.name" value="session-fixer.jar"/>
    <property name="props.template" value="cdd-sync-pro/ser-sync.properties.template"/>
    <property name="session.props.template" value="session-fixer/session-fixer.properties.template"/>
    <property name="main.class" value="ser_sync_main"/>
    <property name="session.main.class" value="session_fixer_main"/>
    
    <!-- Compiler settings -->
    <property name="java.source" value="11"/>
    <property name="java.target" value="11"/>
    
    <!-- Clean target -->
    <target name="clean" description="Remove all generated files">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
        <delete dir="${session.dist.dir}"/>
    </target>
    
    <!-- Compile target -->
    <target name="compile" description="Compile source files">
        <mkdir dir="${build.dir}"/>
        <javac srcdir="${shared.dir}:${src.dir}:session-fixer/src" 
               destdir="${build.dir}" 
               source="${java.source}" 
               target="${java.target}"
               includeantruntime="false"
               debug="on">
        </javac>
    </target>
    
    <!-- Package cdd-sync-pro -->
    <target name="jar" depends="compile" description="Create cdd-sync-pro JAR file">
        <mkdir dir="${dist.dir}"/>
        <jar destfile="${dist.dir}/${jar.name}" basedir="${build.dir}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
                <attribute name="Built-By" value="${user.name}"/>
                <attribute name="Build-Date" value="${TODAY}"/>
            </manifest>
        </jar>
        <copy file="${props.template}" tofile="${dist.dir}/ser-sync.properties"/>
    </target>
    
    <!-- Package session-fixer -->
    <target name="session-fixer-jar" depends="compile" description="Create session-fixer JAR file">
        <mkdir dir="${session.dist.dir}"/>
        <jar destfile="${session.dist.dir}/${session.jar.name}" basedir="${build.dir}">
            <manifest>
                <attribute name="Main-Class" value="${session.main.class}"/>
                <attribute name="Built-By" value="${user.name}"/>
                <attribute name="Build-Date" value="${TODAY}"/>
            </manifest>
        </jar>
        <copy file="${session.props.template}" tofile="${session.dist.dir}/session-fixer.properties"/>
    </target>
    
    <!-- Run cdd-sync-pro -->
    <target name="run" depends="jar" description="Run cdd-sync-pro">
        <java jar="${dist.dir}/${jar.name}" fork="true"/>
    </target>
    
    <!-- Run session-fixer -->
    <target name="session-fixer-run" depends="session-fixer-jar" description="Run session-fixer">
        <java jar="${session.dist.dir}/${session.jar.name}" fork="true"/>
    </target>
    
    <!-- Build all applications -->
    <target name="all" depends="clean, jar, session-fixer-jar" description="Clean and build everything"/>
    
    <!-- Compile and run tests -->
    <target name="test" depends="compile" description="Run unit tests">
        <mkdir dir="out/test-classes"/>
        <javac srcdir="test"
               destdir="out/test-classes"
               source="11" target="11"
               includeantruntime="false">
            <classpath>
                <pathelement location="out/production/cdd-sync-pro"/>
                <fileset dir="lib" includes="*.jar"/>
            </classpath>
        </javac>
        <java jar="lib/junit-platform-console-standalone-1.11.4.jar"
              fork="true" failonerror="true">
            <arg value="execute"/>
            <arg value="--class-path"/>
            <arg value="out/test-classes:out/production/cdd-sync-pro"/>
            <arg value="--select-class"/>
            <arg value="ser_sync_binary_utils_test"/>
            <arg value="--select-class"/>
            <arg value="ser_sync_crate_test"/>        </java>
    </target>
    
</project>